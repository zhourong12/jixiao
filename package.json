  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/server/**/*.spec.ts",
      "<rootDir>/test/unit/**/*.spec.ts",
      "<rootDir>/test/integration/**/*.spec.ts"
    ],
    "moduleNameMapper": {
      "^@server/(.*)$": "<rootDir>/server/$1",
      "^@shared/(.*)$": "<rootDir>/shared/$1"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "actionPlugins": {
    "@official-plugins/send-feishu-message": "1.0.27"
  }
