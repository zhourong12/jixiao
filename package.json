{
  "name": "jixiao2",
  "version": "2.2.3",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n api,client -c blue,green \"npm run dev:server-java\" \"npm run dev:client\"",
    "dev:server-java": "node scripts/run-server-java.mjs",
    "dev:server": "npm run dev:server-java",
    "dev:client": "cross-env NODE_ENV=development CLIENT_DEV_PORT=5174 npm run dev --prefix client-vue",
    "build": "node scripts/package.mjs",
    "build:prod": "npm run build:server-java && npm run build:client && node scripts/copy-server-jar-to-dist.mjs",
    "build:server-java": "node scripts/build-server-java.mjs",
    "package": "node scripts/package.mjs",
    "build:server": "npm run build:server-java",
    "build:client": "npm run build --prefix client-vue",
    "start": "cd server-java && java -jar target/server-0.0.1-SNAPSHOT.jar",
    "test:playwright": "playwright test",
    "newman:build": "node scripts/newman/build-collection.mjs",
    "test:newman:prepare": "node scripts/newman/seed-test-data.mjs",
    "test:newman": "newman run scripts/newman/jixiao2-api.postman_collection.json -e scripts/newman/local.postman_environment.json --delay-request 100",
    "test:newman:full": "npm run test:newman:prepare && npm run newman:build && npm run test:newman",
    "test:devteam:api": "node scripts/devteam-verify.mjs",
    "test:devteam:ui": "playwright test test/playwright/devteam-ui.spec.ts",
    "test:devteam": "npm run test:devteam:api && npm run test:newman:full && npm run test:devteam:ui",
    "typecheck": "npm run typecheck --prefix client-vue"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "newman": "6.2.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
