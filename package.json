{
  "name": "fullstack-nestjs-template",
  "version": "2.2.3",
  "private": true,
  "flags": {
    "supportBusinessUser": true,
    "supportScrollReveal": true,
    "supportTiptapAndStreamdown": true,
    "customToaster": true
  },
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cross-env NODE_ENV=development FORCE_AUTHN_INNERAPI_DOMAIN=http://127.0.0.1:3000 node -r dotenv/config ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "dev:client": "cross-env NODE_ENV=development vite --config vite.config.ts --port 8080",
    "gen:db-schema": "fullstack-cli gen-db-schema",
    "gen:openapi": "echo 'UNSUPPORTED, SKIP'",
    "build": "sh ./scripts/build.sh",
    "build:prod": "npm run build:server && npm run build:client",
    "build:server": "cross-env NODE_ENV=production nest build",
    "build:client": "cross-env NODE_ENV=production vite build --config vite.config.ts",
    "start": "cross-env NODE_ENV=production FORCE_AUTHN_INNERAPI_DOMAIN=http://127.0.0.1:3000 node dist/server/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:integration": "cross-env JIXIAO_INTEGRATION=1 jest --testPathPattern=integration",
    "test:playwright": "playwright test",
    "newman:build": "node scripts/newman/build-collection.mjs",
    "test:newman": "newman run scripts/newman/jixiao2-api.postman_collection.json -e scripts/newman/local.postman_environment.json --delay-request 100",
    "test:e2e": "jest --config test/e2e/jest.config.js",
    "eslint": "eslint . --quiet",
    "stylelint": "stylelint client/src/**/*.css --quiet",
    "type:check": "concurrently -n \"server,client\" -c \"blue,green\" \"npm run type:check:server\" \"npm run type:check:client\"",
    "type:check:client": "tsc --noEmit --project tsconfig.app.json",
    "type:check:server": "tsc --noEmit --project tsconfig.node.json",
    "lint": "node ./scripts/lint.js",
    "format": "prettier --write \"{server,client,test}/**/*.{js,ts,tsx,json,md}\"",
    "postinstall": "fullstack-cli action-plugin init"
  },
  "dependencies": {
    "@lark-apaas/fullstack-nestjs-core": "^1.1.46",
    "@larksuiteoapi/node-sdk": "^1.63.1",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.20",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^7.4.2",
    "@tanstack/react-form": "^1.27.6",
    "@tanstack/react-query": "^5.90.12",
    "axios": "^1.12.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.15",
    "dotenv": "^17.2.2",
    "drizzle-orm": "0.44.6",
    "hbs": "^4.2.0",
    "http-proxy": "^1.18.1",
    "mysql2": "^3.14.0",
    "reflect-metadata": "^0.1.14",
    "tslib": "^2.8.1"
