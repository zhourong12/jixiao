# 测试环境配置示例
#   cp deploy/.env-test.example deploy/.env-test
#   DEPLOY_ENV=test ./deploy/start-api.sh
#   DEPLOY_ENV=test ./deploy/start-web.sh
#
# 与正式环境 deploy/.env 分离；同一台机器并存时请区分端口与 runtime 路径。

JIXIAO2_JDBC_URL=jdbc:mysql://127.0.0.1:3306/jixiao_test?characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true
JIXIAO2_JDBC_USER=root
JIXIAO2_JDBC_PASSWORD=
SESSION_JWT_SECRET=change-me-test-env-only
JIXIAO2_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*
JIXIAO2_SESSION_COOKIE_PATH=/
JIXIAO2_SESSION_COOKIE_DOMAIN=
JIXIAO2_SESSION_COOKIE_SAME_SITE=Lax
JIXIAO2_SESSION_COOKIE_SECURE=auto
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=
JIXIAO2_PUBLIC_APP_URL=
JIXIAO2_FEISHU_WEB_APP_URL=
JIXIAO2_FEISHU_WEB_APP_LINK_APP_ID=
JIXIAO2_FEISHU_WEB_APP_LINK_APP_SECRET=
JIXIAO2_FEISHU_PERFORMANCE_NOTIFY=true

# 与正式错开端口（start-api / start-web 会读取）
API_PORT=8082
WEB_PORT=5175
API_UPSTREAM=127.0.0.1:8082

# 可选：测试环境独立 pid / 日志（路径请按部署机实际填写）
# LOG=/path/to/jixiao2/deploy/runtime-test/api.log
# PID_FILE=/path/to/jixiao2/deploy/runtime-test/api.pid
# RUNTIME_DIR=/path/to/jixiao2/deploy/runtime-test
