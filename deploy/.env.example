# 正式环境：仅放密钥与飞书应用凭证（域名、CORS、回调 URL 在 start-api.sh / start-web.sh 内写死）
#   cp deploy/.env.example deploy/.env
#   ./deploy/start-api.sh && ./deploy/start-web.sh

JIXIAO2_JDBC_USER=root
JIXIAO2_JDBC_PASSWORD=
SESSION_JWT_SECRET=change-me-prod
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 可选：网页应用入口、角标专用应用等（不配则用脚本内 kpi.ccka.com）
JIXIAO2_FEISHU_WEB_APP_URL=
JIXIAO2_FEISHU_WEB_APP_LINK_APP_ID=
JIXIAO2_FEISHU_WEB_APP_LINK_APP_SECRET=
JIXIAO2_FEISHU_PERFORMANCE_NOTIFY=true
