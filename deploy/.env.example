# 正式环境配置（默认 DEPLOY_ENV=prod，读取本文件 deploy/.env）
# 测试环境见 deploy/.env-test.example，复制为 deploy/.env-test 后使用 DEPLOY_ENV=test 启动
#
#   ./deploy/start-api.sh
#   DEPLOY_ENV=test ./deploy/start-api.sh

JIXIAO2_JDBC_URL=jdbc:mysql://127.0.0.1:3306/jixiao?characterEncoding=utf8&useSSL=false&allowPublicKeyRetrieval=true
JIXIAO2_JDBC_USER=root
JIXIAO2_JDBC_PASSWORD=e+ZmCeLXY9UBqbbS
SESSION_JWT_SECRET=112344556445311
JIXIAO2_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,http://172.25.1.43:*
JIXIAO2_SESSION_COOKIE_PATH=/
JIXIAO2_SESSION_COOKIE_DOMAIN=
JIXIAO2_SESSION_COOKIE_SAME_SITE=Lax
JIXIAO2_SESSION_COOKIE_SECURE=auto
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 通知管理「按人发飞书私聊」使用同一应用 tenant 发 IM，须在开放平台为应用申请发消息相关权限（如 im:message），并启用应用机器人能力
# 绩效节点同步创建飞书「任务/待办」(task v2) 时，自建应用还须具备任务写权限（如 task:task:write 等，以开放平台为准）
# 须与飞书开放平台「重定向 URL」完全一致；一般为前端回调页（用户浏览器先回到此地址，再跳转 /auth/feishu/exchange 换票写 Cookie）
# 示例（Vite 默认端口）：http://172.25.1.43:5174/feishu-callback
FEISHU_REDIRECT_URI=
# 绩效流程飞书通知文末可选链接（浏览器站点根地址，无则省略）
JIXIAO2_PUBLIC_APP_URL=
# 飞书网页应用入口（可选）；若设置，绩效卡片 card_link 与文末链接优先用此地址，否则用 JIXIAO2_PUBLIC_APP_URL
JIXIAO2_FEISHU_WEB_APP_URL=
# 绩效卡片「打开网页应用」AppLink 专用应用（可与 FEISHU_APP_ID 不同）；两者皆空且未配上面 URL 时用 AppLink
JIXIAO2_FEISHU_WEB_APP_LINK_APP_ID=
JIXIAO2_FEISHU_WEB_APP_LINK_APP_SECRET=
# 是否自动发绩效节点飞书私聊：true/false
JIXIAO2_FEISHU_PERFORMANCE_NOTIFY=true
